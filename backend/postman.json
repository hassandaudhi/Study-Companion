    {
      "name": "Agents",
      "item": [
        {
          "name": "Summarizer Agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"chat_id\": 1,\n  \"input_text\": \"Long text to summarize...\",\n  \"file_id\": null,\n  \"parameters\": {\n    \"summary_length\": \"medium\",\n    \"focus_areas\": [\"key_points\", \"conclusion\"]\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/agent/summarizer",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "agent", "summarizer"]
            },
            "description": "Generate a summary from input text or uploaded file. Either input_text or file_id must be provided. Parameters are optional."
          },
          "response": []
        },
        {
          "name": "Question Generator Agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"chat_id\": 1,\n  \"input_text\": \"Text to generate questions from...\",\n  \"file_id\": null,\n  \"parameters\": {\n    \"num_questions\": 5,\n    \"difficulty\": \"medium\",\n    \"question_types\": [\"multiple_choice\", \"essay\"]\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/agent/question_generator",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "agent", "question_generator"]
            },
            "description": "Generate quiz questions from input text or uploaded file. Either input_text or file_id must be provided. Parameters control the number, difficulty, and types of questions."
          },
          "response": []
        },
        {
          "name": "Explainer Agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"chat_id\": 1,\n  \"input_text\": \"Concept or question to explain\",\n  \"file_id\": null,\n  \"parameters\": {\n    \"context_depth\": \"detailed\",\n    \"include_examples\": true\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/agent/explainer",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "agent", "explainer"]
            },
            "description": "Provide context-aware explanations for a question. Input_text is required. User_id is required for RAG context retrieval. Chat_id is optional for storing the exchange."
          },
          "response": []
        },
        {
          "name": "Resource Recommender Agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"chat_id\": 1,\n  \"input_text\": \"Topic for which to recommend resources\",\n  \"file_id\": null,\n  \"parameters\": {\n    \"resource_types\": [\"articles\", \"videos\", \"books\"],\n    \"max_resources\": 10\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/agent/resource_recommender",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "agent", "resource_recommender"]
            },
            "description": "Recommend learning resources based on a topic or content. Input_text is required. Parameters control resource types and quantity."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Workflows",
      "item": [
        {
          "name": "Run Workflow",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"chat_id\": 1,\n  \"workflow_type\": \"pdf_processing\",\n  \"input_data\": {\n    \"input_text\": \"Full document text here\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/workflow/run",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "workflow", "run"]
            },
            "description": "Trigger a multi-agent workflow. Supported types: 'pdf_processing' (Upload PDF → Summarize → Generate Questions → Recommend Resources) and 'multi_agent_chat' (Context retrieval → Agent response → Store embeddings). Returns 202 Accepted status as workflows run in background."
          },
          "response": []
        },
