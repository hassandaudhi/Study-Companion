    {
      "name": "Memory & Embeddings",
      "item": [
        {
          "name": "Create Embeddings",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"texts\": [\n    \"First text chunk to embed\",\n    \"Second text chunk to embed\",\n    \"Third text chunk to embed\"\n  ],\n  \"file_id\": 1,\n  \"content_type\": \"general\",\n  \"metadata\": {\n    \"source\": \"uploaded_document\",\n    \"chapter\": \"introduction\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/memory/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "memory", ""]
            },
            "description": "Create embeddings and store in Pinecone and PostgreSQL using RAG pipeline. Texts list cannot be empty. Content_type can be 'summary', 'question', 'explanation', 'resource', or 'general'. Metadata and file_id are optional."
          },
          "response": []
        },
        {
          "name": "Search Embeddings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/memory/search?query=search_term&user_id=1&top_k=5&content_type=general",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "memory", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "search_term"
                },
                {
                  "key": "user_id",
                  "value": "1"
                },
                {
                  "key": "top_k",
                  "value": "5"
                },
                {
                  "key": "content_type",
                  "value": "general"
                }
              ]
            },
            "description": "Search for similar embeddings based on query. Query cannot be empty. Top_k must be between 1 and 50 (default: 5). Content_type filter is optional."
          },
          "response": []
        },
        {
          "name": "Get User Memories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/memory/user/1?skip=0&limit=100",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "memory", "user", "1"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            },
            "description": "Get all memory records for a user with pagination support"
          },
          "response": []
        },
        {
          "name": "Delete Memory",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/memory/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "memory", "1"]
            },
            "description": "Delete memory embedding from both Pinecone and PostgreSQL. Returns 204 No Content on success."
          },
          "response": []
        },
        {
          "name": "Get Memory Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/memory/stats",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "memory", "stats"]
            },
            "description": "Get statistics about the memory/embeddings index"
          },
          "response": []
        }
      ]
