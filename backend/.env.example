# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_study_companion
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_study_companion

# Google Gemini Configuration
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-pro
GEMINI_EMBEDDING_MODEL=models/embedding-001
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=ai-study-companion

# Application Settings
APP_NAME="AI Study Companion Pro"
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# File Storage
STORAGE_TYPE=local  # local or s3
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-study-companion

# JWT/Authentication (Optional)
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LangChain Settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
